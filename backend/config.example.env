# 碳管师收资系统配置文件

# 阿里云 API 配置
DASHSCOPE_API_KEY=your_api_key_here

# 向量数据库配置
VECTOR_DB_TYPE=milvus  # 可选: milvus, qdrant, pgvector
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=carbon_knowledge

# 向量嵌入配置
EMBEDDING_MODEL=text-embedding-v2  # 阿里云 text-embedding-v2
EMBEDDING_DIM=1536  # text-embedding-v2 向量维度

# LLM 配置
LLM_MODEL=qwen-turbo  # 可选: qwen-turbo, qwen-plus, qwen-max
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
