# 阿里云 DashScope API
DASHSCOPE_API_KEY=your_api_key_here

# 数据库配置
DATABASE_URL=postgresql://tantan_user:tantan_password@localhost:5432/tantan

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# 向量数据库类型 (milvus/qdrant/pgvector)
VECTOR_DB_TYPE=pgvector

# PGVector 配置
PGVECTOR_CONN=postgresql://tantan_user:tantan_password@localhost:5432/tantan

# Milvus 配置（如果用 Milvus）
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=carbon_knowledge

# Qdrant 配置（如果用 Qdrant）
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=carbon_knowledge

# Embedding 配置
EMBEDDING_MODEL=text-embedding-v2
EMBEDDING_DIM=1536

# LLM 配置
LLM_MODEL=qwen-turbo
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
